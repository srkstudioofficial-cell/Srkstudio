<!DOCTYPE html>
<html>
<head>
  <title>SRK Studio</title>
  <style>
    #welcomeVideo {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 9999;
    }
  </style>
</head>
<body>

  <!-- Welcome Video -->
  <video id="welcomeVideo" autoplay muted>
    <source src="welcome.mp4" type="video/mp4">
  </video>

  <!-- Main Content -->
  <h1>Welcome to SRK Studio 🚀</h1>

  <script>
    setTimeout(function () {
      var video = document.getElementById("welcomeVideo");
      video.style.display = "none";
    }, 2000); // 2 second
  </script>

</body>
</html>
